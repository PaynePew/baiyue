# Copy to .env (local) or .env.prod (on the box) and fill in real values.
# Server-side (Remix loaders) — Contentful content delivery API:
CONTENTFUL_SPACE_ID=
CONTENTFUL_ACCESS_TOKEN=

# Client-side Google Maps JS API key (Contact page).
# Referrer-restrict this key to the live domain in Google Cloud Console.
REACT_APP_GOOGLEMAP_API_KEY=

# Runtime:
NODE_ENV=production
PORT=3000

# Optional load-shed concurrency cap (default 32).
BAIYUE_MAX_INFLIGHT=32
